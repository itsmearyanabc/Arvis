# Arvis 0.0.1 Configuration Settings

# LLM Providers (Required for Harvesting)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=

# Arvis Core Settings
# If set to 'local', Arvis will attempt to use a local weights file.
# If set to 'api', Arvis will use a remote API (useful for testing initially).
ARVIS_BACKEND=api
ARVIS_MODEL_PATH=./brain/weights/arvis-v0.0.1.bin

# Interface Settings
# Voice options: 'en-US-GuyNeural' (Jarvis-like), 'en-US-JennyNeural' (Friday-like)
ARVIS_VOICE=en-US-GuyNeural

# Sandbox Settings
# Name of the Docker image to use for self-improvement testing.
SANDBOX_IMAGE=python:3.10-slim
